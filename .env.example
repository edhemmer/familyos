VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Server-only integration boundary variables. Do not prefix these with VITE_.
# Rotate any value that was pasted into chat, logs, screenshots, or support tools.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# Plaid sandbox proof variables. Server-only: never prefix with VITE_ and never commit real secrets.
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox

# Server-only token vault key. Never prefix with VITE_ and never commit a real value.
# Use at least 32 bytes of strong random secret material before persistent Plaid token storage is enabled.
TOKEN_ENCRYPTION_KEY=

